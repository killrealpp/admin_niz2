# Скопируйте в .env и заполните значения
# cp .env.example .env   (Linux/Mac)  |  copy .env.example .env   (Windows)

APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Europe/Moscow
SESSION_TTL_HOURS=72
HOLD_TTL_MINUTES=10
HANDOFF_TTL_MINUTES=60
MESSAGE_SUMMARY_ENABLED=true
MESSAGE_SUMMARY_AFTER_HOURS=72
MESSAGE_SUMMARY_INTERVAL_SECONDS=3600
MESSAGE_SUMMARY_BATCH_CONVERSATIONS=20

DB_HOST=localhost
# Beget managed PostgreSQL обычно 5432
DB_PORT=5432
DB_NAME=booking_bot
DB_USER=booking_user
DB_PASSWORD=change_me
DB_CHARSET=utf8mb4
DB_SSLMODE=verify-full
DB_SSLROOTCERT=~/.postgresql/root.crt
DB_TARGET_SESSION_ATTRS=read-write
DB_CONNECT_TIMEOUT=15

TELEGRAM_BOT_TOKEN=change_me
TELEGRAM_WEBHOOK_URL=

AI_PROVIDER=openrouter
OPENAI_API_KEY=
OPENROUTER_API_KEY=change_me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=anthropic/claude-sonnet-4
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=700
VOICE_TRANSCRIPTION_ENABLED=false
VOICE_TRANSCRIPTION_PROVIDER=openrouter
VOICE_TRANSCRIPTION_MODEL=openai/whisper-large-v3
VOICE_TRANSCRIPTION_LANGUAGE=ru
VOICE_TRANSCRIPTION_MAX_SECONDS=120

YCLIENTS_BASE_URL=https://api.yclients.com/api/v1
YCLIENTS_PARTNER_TOKEN=change_me
YCLIENTS_USER_TOKEN=change_me
YCLIENTS_COMPANY_ID=change_me
YCLIENTS_SYNC_ENABLED=true
YCLIENTS_SYNC_INTERVAL_SECONDS=5
YCLIENTS_SYNC_DAYS_BACK=1
YCLIENTS_SYNC_DAYS_FORWARD=60

MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=

PAYMENT_PROVIDER=
PAYMENT_SHOP_ID=
PAYMENT_SECRET_KEY=
PAYMENT_SUCCESS_URL=
PAYMENT_FAIL_URL=
PREPAYMENT_AMOUNT_RUB=2000
PAYMENT_STATUS_SYNC_ENABLED=true
PAYMENT_STATUS_SYNC_INTERVAL_SECONDS=60
YOOKASSA_WEBHOOK_ENABLED=false
YOOKASSA_WEBHOOK_HOST=0.0.0.0
YOOKASSA_WEBHOOK_PORT=8088
YOOKASSA_WEBHOOK_PATH=/webhooks/yookassa
YOOKASSA_WEBHOOK_SECRET=
# Public URL to register in YooKassa dashboard/API, for example https://domain.ru/webhooks/yookassa?secret=...
YOOKASSA_WEBHOOK_URL=

ADMIN_TELEGRAM_CHAT_ID=change_me

LOG_LEVEL=INFO
